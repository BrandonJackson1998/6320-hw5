__pycache__/
*.py[cod]
.DS_Store
.venv/
venv/

# Large prepared split CSVs — regenerate with scripts/prepare_bgg_data.py
prep/bgg_split/data/*.csv
!prep/bgg_split/data/.gitkeep

outputs/*
!outputs/.gitkeep
!outputs/experiment_manifest.json
!outputs/baseline_unweighted_l2/
!outputs/intervention_balanced_class_weight/
!outputs/plots/
!outputs/error_analysis/

outputs/baseline_unweighted_l2/*
!outputs/baseline_unweighted_l2/*.csv
!outputs/baseline_unweighted_l2/*.json

outputs/intervention_balanced_class_weight/*
!outputs/intervention_balanced_class_weight/*.csv
!outputs/intervention_balanced_class_weight/*.json

outputs/plots/*
!outputs/plots/*.png

outputs/error_analysis/*
!outputs/error_analysis/*.csv

logs/*
!logs/.gitkeep
!logs/run_local.log
